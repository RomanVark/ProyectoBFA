create table IMAGES (ID varchar(32) not null, GALLERY varchar(32), image varbinary(16777216), primary key (ID))
create table OXDISCUSSIONCOMMENTS (id varchar(32) not null, "COMMENT" clob(16777216), discussionId varchar(32), time timestamp, userName varchar(30), primary key (id))
create table perfil_bfa (idPerfil integer generated by default as identity (start with 1), fecha_generacion date, observaciones_general varchar(1000), id_sesion integer not null, primary key (idPerfil))
create table pregunta (idPregunta integer generated by default as identity (start with 1), enunciado varchar(500) not null, numero_pregunta integer not null, respuesta_correcta varchar(10) not null, tipo_pregunta varchar(50) not null, id_test integer not null, primary key (idPregunta))
create table psicologo (idUsuario integer generated by default as identity (start with 1), correo varchar(150) not null, nombre varchar(100) not null, codigoColegido varchar(50) not null, especialidad varchar(100), primary key (idUsuario))
create table respuesta_sujeto (idRespuesta integer generated by default as identity (start with 1), es_correcta boolean not null, estado varchar(30) not null, fecha_inicio timestamp, respuesta_marcada varchar(10), id_pregunta integer not null, id_sesion integer not null, primary key (idRespuesta))
create table resultado_factor (idResultado integer generated by default as identity (start with 1), accionimo_factor varchar(50) not null, percentil integer, puntaje_directo integer, puntuacion_tipica integer, id_perfil integer not null, primary key (idResultado))
create table sesion_evaluacion (idSesion integer generated by default as identity (start with 1), estado varchar(30) not null, fecha_fin timestamp, fecha_inicio timestamp, finalidad varchar(255), id_psicologo integer not null, id_sujeto integer not null, primary key (idSesion))
create table sujeto (idUsuario integer generated by default as identity (start with 1), correo varchar(150) not null, nombre varchar(100) not null, edad integer, estudiosRealizados varchar(200), fecha_nacimiento date, genero varchar(20) not null, profesion varchar(100), primary key (idUsuario))
create table test_aptitud (idTest integer generated by default as identity (start with 1), instrucciones varchar(500), nombre_test varchar(100) not null, tiempo_limite integer, tipo_test varchar(50) not null, primary key (idTest))
create table test_espacial (tipo_movimiento varchar(50) not null, id_test integer not null, primary key (id_test))
